{
  "name": "@rcrsr/rill-cli",
  "version": "0.19.0",
  "description": "CLI tools for the rill scripting language",
  "license": "MIT",
  "author": "Andre Bremer",
  "type": "module",
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "keywords": [
    "rill",
    "cli",
    "scripting",
    "exec",
    "eval",
    "build"
  ],
  "bin": {
    "rill-exec": "./dist/cli-exec.js",
    "rill-eval": "./dist/cli-eval.js",
    "rill-check": "./dist/cli-check.js",
    "rill-run": "./dist/cli-run.js",
    "rill-build": "./dist/cli-build.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "build:dev": "tsc --build tsconfig.dev.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "check": "pnpm run build && pnpm run test && pnpm run lint"
  },
  "dependencies": {
    "@rcrsr/rill": "~0.19.0",
    "@rcrsr/rill-config": "~0.19.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0"
  },
  "peerDependencies": {
    "@rcrsr/rill": "~0.19.0",
    "@rcrsr/rill-config": "~0.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rcrsr/rill": "~0.19.0",
    "@rcrsr/rill-config": "~0.19.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rcrsr/rill-cli.git"
  },
  "homepage": "https://github.com/rcrsr/rill-cli",
  "bugs": {
    "url": "https://github.com/rcrsr/rill-cli/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "vite>esbuild": "0.28.x"
      }
    }
  }
}
