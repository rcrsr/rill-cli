{
  "name": "@rcrsr/rill-cli",
  "version": "0.19.6",
  "description": "CLI tools for the rill scripting language",
  "license": "MIT",
  "author": "Andre Bremer",
  "type": "module",
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "keywords": [
    "rill",
    "cli",
    "scripting",
    "exec",
    "eval",
    "build"
  ],
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./harness": {
      "types": "./dist/harness.d.ts",
      "import": "./dist/harness.js"
    }
  },
  "bin": {
    "rill": "./dist/cli.js"
  },
  "engines": {
    "node": ">=22.16.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "lefthook install --force",
    "build": "tsc --build",
    "build:dev": "tsc --build tsconfig.dev.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --config .oxlintrc.json src/ tests/",
    "check": "pnpm run build && pnpm run test && pnpm run check:lint",
    "check:types": "tsc --noEmit",
    "check:lint": "pnpm run lint",
    "check:format": "oxfmt --check",
    "check:deps": "knip",
    "fix:lint": "oxlint --config .oxlintrc.json --fix src/ tests/",
    "fix:format": "oxfmt",
    "prepublishOnly": "node scripts/check-no-local-specifiers.mjs"
  },
  "dependencies": {
    "@rcrsr/rill": "~0.19.6",
    "@rcrsr/rill-config": "~0.19.2",
    "@rcrsr/rill-language-service": "~0.19.6",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0"
  },
  "peerDependencies": {
    "@rcrsr/rill": "~0.19.6",
    "@rcrsr/rill-config": "~0.19.2",
    "@rcrsr/rill-language-service": "~0.19.6"
  },
  "devDependencies": {
    "@rcrsr/rill": "~0.19.6",
    "@rcrsr/rill-config": "~0.19.2",
    "@rcrsr/rill-language-service": "~0.19.6",
    "@rcrsr/rill-ext-datetime": "~0.19.0",
    "@types/node": "^26.1.1",
    "knip": "^6.25.0",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rcrsr/rill-cli.git"
  },
  "homepage": "https://github.com/rcrsr/rill-cli",
  "bugs": {
    "url": "https://github.com/rcrsr/rill-cli/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "vite>esbuild": "0.28.x"
      }
    }
  }
}
